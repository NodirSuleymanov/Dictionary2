    {"de": "Alles Gute!", "uz": "Hammasi yaxshi bo'lsin!", "type": "phrase"},
    {"de": "Gute Besserung!", "uz": "Tezroq tuzalib keting!", "type": "phrase"},
    {"de": "Viel Erfolg!", "uz": "Omad tilayman!", "type": "phrase"},
